# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Database
POSTGRES_DB=nptu_assistant
POSTGRES_USER=nptu
POSTGRES_PASSWORD=change-me-in-local-env
DATABASE_URL=postgresql+psycopg://nptu:change-me-in-local-env@db:5432/nptu_assistant

# OpenAI: keep the real value only in .env.local or the process environment
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai

# API security
ADMIN_API_ENABLED=true
ADMIN_API_KEY=replace-with-a-long-random-development-key
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Crawler
CRAWLER_CONFIG_PATH=data/sources/announcements.yaml
OFFICIAL_DOCUMENTS_PATH=data/official-documents
CRAWLER_USER_AGENT=NPTU-Campus-Assistant/0.1 (non-official local development)
CRAWLER_REQUEST_INTERVAL_SECONDS=1

# Extension build
WXT_API_BASE_URL=http://127.0.0.1:8000
